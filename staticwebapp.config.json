{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": []
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,scss,gif,jpg,jpeg,js,png,svg,webp,woff,woff2}"]
  },
  "env": "production",
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
